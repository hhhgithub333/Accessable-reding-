<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floating_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/drag_handle_bg"
    android:elevation="24dp"
    android:padding="0dp">

    <!-- 顶部拖动把手区域 -->
    <RelativeLayout
        android:id="@+id/drag_handle_area"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="#1A1A2E">

        <!-- 居中拖动条 -->
        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:background="#4A4A6A"
            android:layout_centerInParent="true"
            android:layout_marginTop="14dp"
            android:layout_alignParentTop="true" />

        <!-- 关闭按钮（右上角） -->
        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/btn_close_bg"
            android:src="@drawable/ic_close"
            android:scaleType="center"
            android:contentDescription="关闭"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="6dp" />

    </RelativeLayout>

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A3E" />

    <!-- 状态行 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="● 已就绪"
            android:textSize="12sp"
            android:textColor="#4CAF50"
            android:letterSpacing="0.02" />

        <TextView
            android:id="@+id/tv_current_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="请先设置模型"
            android:textColor="#4A4A6A"
            android:textSize="11sp" />

    </LinearLayout>

    <!-- 当前朗读文字预览 -->
    <TextView
        android:id="@+id/tv_reading_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="12dp"
        android:text="等待捕获文字…"
        android:textSize="12sp"
        android:textColor="#7A7A9A"
        android:maxLines="2"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.4" />

    <!-- 分割线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A3E" />

    <!-- 控制按钮栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp">

        <!-- 倍速按钮 -->
        <ImageButton
            android:id="@+id/btn_speed"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginEnd="8dp"
            android:background="#2A2A3E"
            android:scaleType="center"
            android:src="@drawable/ic_speed" />

        <!-- 倍速显示文字 -->
        <TextView
            android:id="@+id/tv_speed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="倍速1.0x"
            android:textSize="14sp"
            android:textColor="#7A7A9A"
            android:textStyle="bold"
            android:layout_marginEnd="20dp" />

        <!-- 播放/暂停按钮（主操作，最大） -->
        <ImageButton
            android:id="@+id/btn_play_pause"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="20dp"
            android:background="@drawable/button_play"
            android:scaleType="center"
            android:src="@drawable/ic_play" />

        <!-- 停止按钮 -->
        <ImageButton
            android:id="@+id/btn_stop"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/button_stop"
            android:scaleType="center"
            android:src="@drawable/ic_stop" />

    </LinearLayout>

</LinearLayout>