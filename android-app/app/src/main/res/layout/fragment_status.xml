<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">


    <!-- 顶部纯色标题区域 -->
    <LinearLayout

        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="21dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="权限状态"
            android:textColor="#1F2937"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:alpha="0.85"
            android:text="确保所有权限已开启以正常使用"
            android:textColor="#1F2937"
            android:textSize="14sp" />


        <!-- 主内容区域 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="10dp">

            <!-- 状态卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- 服务状态 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="16dp">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/circle_icon_bg_service">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_service_icon"
                                app:tint="#FFFFFF" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="服务运行状态"
                                android:textSize="16sp"
                                android:textColor="#1F2937" />

                            <TextView
                                android:id="@+id/tv_service_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="未启动"
                                android:textSize="13sp"
                                android:textColor="#9CA3AF"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/iv_service_status"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_status_off"
                            app:tint="#D1D5DB" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F3F4F6" />

                    <!-- 悬浮窗权限 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="16dp">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/circle_icon_bg_overlay">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_overlay_icon"
                                app:tint="#FFFFFF" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="悬浮窗权限"
                                android:textSize="16sp"
                                android:textColor="#1F2937" />

                            <TextView
                                android:id="@+id/tv_overlay_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="未开启"
                                android:textSize="13sp"
                                android:textColor="#9CA3AF"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/iv_overlay_status"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_status_off"
                            app:tint="#D1D5DB" />

                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#F3F4F6" />

                    <!-- 无障碍服务 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="16dp">

                        <FrameLayout
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/circle_icon_bg_access">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_accessibility_icon"
                                app:tint="#FFFFFF" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="无障碍服务"
                                android:textSize="16sp"
                                android:textColor="#1F2937" />

                            <TextView
                                android:id="@+id/tv_accessibility_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="未开启"
                                android:textSize="13sp"
                                android:textColor="#9CA3AF"
                                android:layout_marginTop="4dp" />

                        </LinearLayout>

                        <ImageView
                            android:id="@+id/iv_accessibility_status"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_status_off"
                            app:tint="#D1D5DB" />

                    </LinearLayout>

                </LinearLayout>


            </com.google.android.material.card.MaterialCardView>

            <!-- 提示卡片 -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#FEF3C7"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_warning"
                        app:tint="#D97706" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="未开启权限将无法使用文本捕获和语音播报功能"
                        android:textSize="13sp"
                        android:textColor="#92400E"
                        android:layout_marginStart="12dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- 设置按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_go_settings"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="去设置"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                app:cornerRadius="26dp"
                app:backgroundTint="#3B82F6"
                app:elevation="0dp"
                android:layout_marginBottom="32dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>